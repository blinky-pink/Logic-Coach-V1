{% extends 'base.html.twig' %}

{% block title %}Connexion - Logic Coach{% endblock %}

{% block body %}

<main class="login-page">

    <section class="login-section">

        <div class="login-title-container">
            <h1>Logic Coach</h1>
        </div>

        <div class="login-subtitle-container">
            <p>Votre coach de bien-être quotidien</p>
        </div>

        <div class="login-main-container">

            <div class="login-form-container">

                <form method="post" class="login-form">

                    {% if error %}
                        <div class="login-error-container">
                            {{ error.messageKey|trans(error.messageData, 'security') }}
                        </div>
                    {% endif %}

                    {% if app.user %}
                        <div class="login-user-container">
                            Vous êtes connecté avec {{ app.user.userIdentifier }}.
                            <br>
                            <a href="{{ logout_path() }}">Se déconnecter</a>
                        </div>
                    {% endif %}

                    <div class="login-form-title-container">
                        <h2>Connexion</h2>
                    </div>

                    <div class="login-email-container">

                        <label for="username">
                            Adresse e-mail
                        </label>

                        <input
                            type="email"
                            id="username"
                            name="_username"
                            value="{{ last_username }}"
                            autocomplete="email"
                            required
                            autofocus
                        >

                    </div>

                    <div class="login-password-container">

                        <label for="password">
                            Mot de passe
                        </label>

                        <input
                            type="password"
                            id="password"
                            name="_password"
                            autocomplete="current-password"
                            required
                        >

                    </div>

                    <input
                        type="hidden"
                        name="_csrf_token"
                        value="{{ csrf_token('authenticate') }}"
                    >

                    <div class="login-button-container">
                        <button type="submit">
                            Se connecter
                        </button>
                    </div>

                    <div class="login-register-container">
                        <a href="{{ path('app_register') }}">
                            Créer un compte
                        </a>
                    </div>

                </form>

            </div>

            <div class="login-info-container">

                <h2>Bienvenue</h2>

                <p>
                    Logic Coach vous accompagne chaque jour
                    dans le suivi de votre bien-être.
                </p>

                <p>
                    Connectez-vous pour retrouver
                    votre tableau de bord,
                    vos indicateurs
                    et vos conseils personnalisés.
                </p>

            </div>

        </div>

        <div class="login-footer-container">

            <a href="{{ path('app_home') }}">
                ← Retour à l'accueil
            </a>

        </div>

    </section>

</main>

{% endblock %}