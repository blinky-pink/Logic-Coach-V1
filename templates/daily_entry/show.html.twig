{% extends 'base.html.twig' %}

{% block title %}Résultat de la saisie - Logic Coach{% endblock %}

{% block body %}
<main class="daily-entry-page">

    <section class="daily-entry-container">

        <header class="daily-entry-header">
            <h1>Résultat de ma saisie</h1>

            <p>
                Consultez le résultat calculé à partir de vos indicateurs.
            </p>
        </header>

        <div class="daily-entry-result">

            <div class="daily-entry-score">
                <span>Score global</span>
                <strong>{{ daily_entry.score }}/50</strong>
            </div>

            <div class="daily-entry-state">
                <span>État du jour</span>
                <strong>{{ daily_entry.state }}</strong>
            </div>

            <div class="daily-entry-indicators">

                <p><strong>Sommeil :</strong> {{ daily_entry.sleepHours }} heures</p>

                <p><strong>Énergie :</strong> {{ daily_entry.energy }}/10</p>

                <p><strong>Stress :</strong> {{ daily_entry.stress }}/10</p>

                <p><strong>Motivation :</strong> {{ daily_entry.motivation }}/10</p>

                <p><strong>Humeur :</strong> {{ daily_entry.mood }}/10</p>

            </div>

            <div class="daily-entry-message">
                <h2>Message</h2>
                <p>{{ daily_entry.message }}</p>
            </div>

            <div class="daily-entry-advice">
                <h2>Conseil</h2>
                <p>{{ daily_entry.advice }}</p>
            </div>

        </div>

        <div class="daily-entry-actions">

            <a
                href="{{ path('app_daily_entry_index') }}"
                class="daily-entry-back"
            >
                Retour à l'historique
            </a>

            <a
                href="{{ path('app_daily_entry_edit', {'id': daily_entry.id}) }}"
                class="daily-entry-back"
            >
                Modifier
            </a>

        </div>

        {{ include('daily_entry/_delete_form.html.twig') }}

    </section>

</main>
{% endblock %}