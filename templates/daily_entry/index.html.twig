{% extends 'base.html.twig' %}

{% block title %}Historique - Logic Coach{% endblock %}

{% block body %}

<main class="daily-entry-page">

    <section class="daily-entry-container">

        <header class="daily-entry-header">
            <h1>Historique de mes saisies</h1>

            <p>
                Retrouvez vos saisies quotidiennes et consultez leur résultat.
            </p>
        </header>

        <div class="daily-entry-actions">

            <a
                href="{{ path('app_daily_entry_new') }}"
                class="daily-entry-submit"
            >
                Nouvelle saisie
            </a>

            <a
                href="{{ path('app_dashboard') }}"
                class="daily-entry-back"
            >
                Retour au tableau de bord
            </a>

        </div>

        {% if daily_entries is empty %}

            <div class="daily-entry-empty">

                <p>
                    Aucune saisie quotidienne enregistrée.
                </p>

            </div>

        {% else %}

            <div class="daily-entry-table-wrapper">

                <table class="daily-entry-table">

                    <thead>

                        <tr>
                            <th>Sommeil</th>
                            <th>Énergie</th>
                            <th>Stress</th>
                            <th>Motivation</th>
                            <th>Humeur</th>
                            <th>Score</th>
                            <th>État</th>
                            <th>Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        {% for daily_entry in daily_entries %}

                            <tr>

                                <td>
                                    {{ daily_entry.sleepHours }} h
                                </td>

                                <td>
                                    {{ daily_entry.energy }}/10
                                </td>

                                <td>
                                    {{ daily_entry.stress }}/10
                                </td>

                                <td>
                                    {{ daily_entry.motivation }}/10
                                </td>

                                <td>
                                    {{ daily_entry.mood }}/10
                                </td>

                                <td>
                                    {{ daily_entry.score }}/50
                                </td>

                                <td>
                                    {{ daily_entry.state }}
                                </td>

                                <td class="daily-entry-table-actions">

                                    <a
                                        href="{{ path(
                                            'app_daily_entry_show',
                                            {'id': daily_entry.id}
                                        ) }}"
                                    >
                                        Consulter
                                    </a>

                                </td>

                            </tr>

                        {% endfor %}

                    </tbody>

                </table>

            </div>

        {% endif %}

    </section>

</main>

{% endblock %}