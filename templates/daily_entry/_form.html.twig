{{ form_start(form, {
    'attr': {
        'class': 'daily-entry-form'
    }
}) }}

    <div class="daily-entry-field">

        {{ form_label(form.sleepHours, 'Sommeil (heures)') }}

        {{ form_widget(form.sleepHours, {
            'attr': {
                'min': 0,
                'max': 24,
                'step': 0.5
            }
        }) }}

        {{ form_errors(form.sleepHours) }}

    </div>

    <div class="daily-entry-field">

        {{ form_label(form.energy, 'Énergie (0 à 10)') }}

        {{ form_widget(form.energy, {
            'attr': {
                'min': 0,
                'max': 10
            }
        }) }}

        {{ form_errors(form.energy) }}

    </div>

    <div class="daily-entry-field">

        {{ form_label(form.stress, 'Stress (0 à 10)') }}

        {{ form_widget(form.stress, {
            'attr': {
                'min': 0,
                'max': 10
            }
        }) }}

        {{ form_errors(form.stress) }}

    </div>

    <div class="daily-entry-field">

        {{ form_label(form.motivation, 'Motivation (0 à 10)') }}

        {{ form_widget(form.motivation, {
            'attr': {
                'min': 0,
                'max': 10
            }
        }) }}

        {{ form_errors(form.motivation) }}

    </div>

    <div class="daily-entry-field">

        {{ form_label(form.mood, 'Humeur (0 à 10)') }}

        {{ form_widget(form.mood, {
            'attr': {
                'min': 0,
                'max': 10
            }
        }) }}

        {{ form_errors(form.mood) }}

    </div>

    <button
        type="submit"
        class="daily-entry-submit"
    >
        Enregistrer
    </button>

{{ form_end(form) }}