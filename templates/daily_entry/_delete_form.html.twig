<form
    method="post"
    action="{{ path('app_daily_entry_delete', {'id': daily_entry.id}) }}"
    onsubmit="return confirm('Voulez-vous vraiment supprimer cette saisie quotidienne ?');"
    class="daily-entry-delete-form"
>
    <input
        type="hidden"
        name="_token"
        value="{{ csrf_token('delete' ~ daily_entry.id) }}"
    >

    <button
        type="submit"
        class="daily-entry-delete"
    >
        Supprimer cette saisie
    </button>
</form>