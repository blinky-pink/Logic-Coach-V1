{% extends 'base.html.twig' %}

{% block title %}Modifier ma saisie - Logic Coach{% endblock %}

{% block body %}
<main class="daily-entry-page">

    <section class="daily-entry-container">

        <header class="daily-entry-header">
            <h1>Modifier ma saisie</h1>

            <p>
                Corrigez vos indicateurs. Le score, l'état, le message et le conseil seront recalculés automatiquement.
            </p>
        </header>

        {{ include('daily_entry/_form.html.twig', {
            'button_label': 'Enregistrer les modifications'
        }) }}

        <div class="daily-entry-actions">

            <a
                href="{{ path('app_daily_entry_show', {'id': daily_entry.id}) }}"
                class="daily-entry-back"
            >
                Retour au résultat
            </a>

            <a
                href="{{ path('app_daily_entry_index') }}"
                class="daily-entry-back"
            >
                Retour à l'historique
            </a>

        </div>

        {{ include('daily_entry/_delete_form.html.twig') }}

    </section>

</main>
{% endblock %}