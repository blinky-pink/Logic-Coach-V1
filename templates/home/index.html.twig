{% extends 'base.html.twig' %}

{% block title %}Logic Coach - Votre coach de bien-être quotidien{% endblock %}

{% block body %}

<main class="home">

    <section class="hero">

        <h1>Logic Coach</h1>

        <p class="subtitle">
            Votre coach de bien-être quotidien
        </p>

        <p class="introduction-top">
            Comprenez votre état quotidien avec des repères simples et clairs.
        </p>

        <p class="introduction-left">
            Prenez un instant pour vous écouter.
        </p>

        <p class="introduction-right">
            Logic Coach vous accompagne.
        </p>

        <div class="hero-content">

            <div class="feature feature-sleep">
                <img src="{{ asset('images/home/sommeil.png') }}" alt="Sommeil">
                <p>Sommeil</p>
            </div>

            <div class="feature feature-energy">
                <img src="{{ asset('images/home/energie.png') }}" alt="Énergie">
                <p>Énergie</p>
            </div>

            <div class="feature feature-stress">
                <img src="{{ asset('images/home/stress.png') }}" alt="Stress">
                <p>Stress</p>
            </div>

            {% if app.user %}

                <a href="{{ path('app_dashboard') }}" class="center-circle">
                    <span>
                        Entrer dans<br>
                        Logic Coach
                    </span>
                </a>

            {% else %}

                <a href="{{ path('app_login') }}" class="center-circle">
                    <span>
                        Entrer dans<br>
                        Logic Coach
                    </span>
                </a>

            {% endif %}

            <div class="feature feature-motivation">
                <img src="{{ asset('images/home/motivation.png') }}" alt="Motivation">
                <p>Motivation</p>
            </div>

            <div class="feature feature-mood">
                <img src="{{ asset('images/home/humeur.png') }}" alt="Humeur">
                <p>Humeur</p>
            </div>

        </div>

    </section>

</main>

{% endblock %}