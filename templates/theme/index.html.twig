{% extends 'base.html.twig' %}

{% block title %}Choix du theme{% endblock %}

{% block body %}
    <h1>Choix du theme</h1>

    {% if current_theme %}
        <p>Theme actuel : {{ current_theme.name }}</p>
    {% else %}
        <p>Aucun theme choisi.</p>
    {% endif %}

    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Description</th>
                <th>Couleur principale</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for theme in themes %}
            <tr>
                <td>{{ theme.name }}</td>

                <td>{{ theme.description }}</td>

                <td>{{ theme.primaryColor }}</td>

                <td>
                    {% if current_theme and current_theme.id == theme.id %}
                        Selectionne
                    {% else %}
                        Disponible
                    {% endif %}
                </td>

                <td>
                    {% if not current_theme or current_theme.id != theme.id %}
                        <form
                            method="post"
                            action="{{ path('app_theme_choose', {'id': theme.id}) }}"
                        >
                            <input
                                type="hidden"
                                name="_token"
                                value="{{ csrf_token('choose' ~ theme.id) }}"
                            >

                            <button class="btn" type="submit">
                                Choisir
                            </button>
                        </form>
                    {% endif %}

                    <a href="{{ path('app_theme_show', {'id': theme.id}) }}">
                        Voir
                    </a>

                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_theme_edit', {'id': theme.id}) }}">
                            Modifier
                        </a>
                    {% endif %}
                </td>
            </tr>

        {% else %}
            <tr>
                <td colspan="5">
                    Aucun theme trouve.
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_theme_new') }}">
            Creer un theme
        </a>
    {% endif %}

    <a href="{{ path('app_dashboard') }}">
        Retour au tableau de bord
    </a>
{% endblock %}