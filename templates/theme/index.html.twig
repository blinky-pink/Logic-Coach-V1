{% extends 'base.html.twig' %}

{% block title %}Choix du thème - Logic Coach{% endblock %}

{% block body %}

<main class="theme-page">

    <section class="theme-container">

        <header class="theme-header">

            <h1>Choix du thème</h1>

            <p>
                Personnalisez l'apparence de votre espace Logic Coach.
            </p>

        </header>

        {% if current_theme %}

            <div class="theme-current">

                <span>Thème actuel</span>

                <strong>
                    {{ current_theme.name }}
                </strong>

            </div>

        {% else %}

            <div class="theme-current">

                <span>Thème actuel</span>

                <strong>
                    Aucun thème choisi
                </strong>

            </div>

        {% endif %}

        <section class="theme-grid">

            {% for theme in themes %}

                <article
                    class="theme-card {% if current_theme and current_theme.id == theme.id %}theme-card-selected{% endif %}"
                >

                    <div
                        class="theme-color"
                        style="background-color: {{ theme.primaryColor }};"
                    ></div>

                    <h2>
                        {{ theme.name }}
                    </h2>

                    <p>
                        {{ theme.description }}
                    </p>

                    <div class="theme-status">

                        {% if current_theme and current_theme.id == theme.id %}

                            <span class="theme-selected">
                                Thème sélectionné
                            </span>

                        {% else %}

                            <span class="theme-available">
                                Disponible
                            </span>

                        {% endif %}

                    </div>

                    <div class="theme-actions">

                        {% if not current_theme or current_theme.id != theme.id %}

                            <form
                                method="post"
                                action="{{ path('app_theme_choose', {'id': theme.id}) }}"
                            >

                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('choose' ~ theme.id) }}"
                                >

                                <button
                                    class="theme-choose-button"
                                    type="submit"
                                >
                                    Choisir ce thème
                                </button>

                            </form>

                        {% endif %}

                        {% if is_granted('ROLE_ADMIN') %}

                            <a
                                href="{{ path('app_theme_edit', {'id': theme.id}) }}"
                                class="theme-admin-button"
                            >
                                Modifier
                            </a>

                        {% endif %}

                    </div>

                </article>

            {% else %}

                <div class="theme-empty">

                    <p>
                        Aucun thème trouvé.
                    </p>

                </div>

            {% endfor %}

        </section>

        <div class="theme-footer-actions">

            {% if is_granted('ROLE_ADMIN') %}

                <a
                    href="{{ path('app_theme_new') }}"
                    class="theme-admin-create"
                >
                    Créer un thème
                </a>

            {% endif %}

            <a
                href="{{ path('app_dashboard') }}"
                class="theme-back-button"
            >
                Retour au tableau de bord
            </a>

        </div>

    </section>

</main>

{% endblock %}