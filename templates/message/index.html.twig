{% extends 'base.html.twig' %}

{% block title %}Boîte de réception{% endblock %}

{% block body %}

<h1>Boîte de réception</h1>

<p>
    <a href="{{ path('app_message_new') }}" class="btn btn-primary">
        Nouveau message
    </a>
</p>

<table class="table">

    <thead>
        <tr>
            <th>Expéditeur</th>
            <th>Message</th>
            <th>Date</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>

    {% for message in messages %}

        <tr>

            <td>{{ message.sender.email }}</td>

            <td>{{ message.message }}</td>

            <td>
                {{ message.createdAt ? message.createdAt|date('d/m/Y H:i') : '' }}
            </td>

            <td>
                <a href="{{ path('app_message_show', {'id': message.id}) }}">
                    Lire
                </a>
            </td>

        </tr>

    {% else %}

        <tr>
            <td colspan="4">
                Aucun message.
            </td>
        </tr>

    {% endfor %}

    </tbody>

</table>

{% endblock %}