{% extends 'base.html.twig' %}

{% block title %}Lecture du message{% endblock %}

{% block body %}

<h1>Lecture du message</h1>

<table class="table">

    <tbody>

        <tr>
            <th>Expéditeur</th>
            <td>{{ message.sender.email }}</td>
        </tr>

        <tr>
            <th>Destinataire</th>
            <td>{{ message.receiver.email }}</td>
        </tr>

        <tr>
            <th>Date</th>
            <td>{{ message.createdAt|date('d/m/Y H:i') }}</td>
        </tr>

        <tr>
            <th>Message</th>
            <td>{{ message.message|nl2br }}</td>
        </tr>

    </tbody>

</table>

<a class="btn btn-secondary" href="{{ path('app_message_index') }}">
    Retour
</a>

{% if app.user == message.sender %}
    <a class="btn btn-warning"
       href="{{ path('app_message_edit', {'id': message.id}) }}">
        Modifier
    </a>

    {{ include('message/_delete_form.html.twig') }}
{% endif %}

{% endblock %}