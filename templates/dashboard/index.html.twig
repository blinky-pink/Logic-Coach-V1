{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}

<main class="dashboard">

    <aside class="sidebar">

        <div class="user-card">

            <img src="{{ asset('images/avatar.png') }}" alt="Avatar">

            <h2>{{ app.user ? app.user.userIdentifier : 'Utilisateur' }}</h2>

            <p>Mon espace personnel</p>

            {% if app.user and app.user.theme %}
                <p>Theme : {{ app.user.theme.name }}</p>
            {% endif %}

        </div>

        <nav class="sidebar-menu">

            <ul>

                <li>
                    <a href="{{ path('app_dashboard') }}">
                        Tableau de bord
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_daily_entry_new') }}">
                        Saisie quotidienne
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_daily_entry_index') }}">
                        Historique
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_theme_index') }}">
                        Choix du theme
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_logout') }}">
                        Deconnexion
                    </a>
                </li>

            </ul>

        </nav>

    </aside>

    <section class="dashboard-content">

        <header class="dashboard-header">

            <h1>Tableau de bord</h1>

        </header>

        {% if latest_daily_entry %}

            <section class="dashboard-grid">

                <article class="card score">

                    <h2>Score global</h2>

                    <p>
                        {{ latest_daily_entry.score }} / 50
                    </p>

                    <p>
                        Etat : {{ latest_daily_entry.state }}
                    </p>

                </article>

                <article class="card indicators">

                    <h2>Indicateurs</h2>

                    <p>
                        Sommeil :
                        {{ latest_daily_entry.sleepHours }} h
                    </p>

                    <p>
                        Energie :
                        {{ latest_daily_entry.energy }} / 10
                    </p>

                    <p>
                        Stress :
                        {{ latest_daily_entry.stress }} / 10
                    </p>

                    <p>
                        Motivation :
                        {{ latest_daily_entry.motivation }} / 10
                    </p>

                    <p>
                        Humeur :
                        {{ latest_daily_entry.mood }} / 10
                    </p>

                </article>

                <article class="card evolution">

                    <h2>Evolution</h2>

                    <p>
                        Consultez votre historique pour suivre
                        l'évolution de vos saisies quotidiennes.
                    </p>

                    <a href="{{ path('app_daily_entry_index') }}">
                        Voir mon historique
                    </a>

                </article>

                <article class="card goals">

                    <h2>Objectifs</h2>

                    <p>
                        Vos objectifs personnels seront affichés ici.
                    </p>

                </article>

                <article class="card messages">

                    <h2>Messages / Conseils</h2>

                    <p>
                        {{ latest_daily_entry.message }}
                    </p>

                    <p>
                        {{ latest_daily_entry.advice }}
                    </p>

                </article>

            </section>

        {% else %}

            <section class="dashboard-empty">

                <h2>Aucune saisie quotidienne enregistrée</h2>

                <p>
                    Effectuez votre première saisie quotidienne
                    pour afficher votre score et vos indicateurs.
                </p>

                <a href="{{ path('app_daily_entry_new') }}">
                    Faire ma première saisie
                </a>

            </section>

        {% endif %}

    </section>

</main>

{% endblock %}