{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - Logic Coach{% endblock %}

{% block body %}

<main class="dashboard">

    <aside class="sidebar">

        <div class="user-card">

            {% if app.user and app.user.avatarFilename %}

                <img
                    src="{{ asset('uploads/avatars/' ~ app.user.avatarFilename) }}"
                    alt="Photo de profil de {{ app.user.pseudo }}"
                    class="user-avatar"
                >

            {% else %}

                <div class="user-avatar-default">
                    {{ app.user.pseudo|first|upper }}
                </div>

            {% endif %}

            <h2>
                {{ app.user ? app.user.pseudo : 'Utilisateur' }}
            </h2>

            <p>Mon espace personnel</p>

            {% if app.user and app.user.theme %}
                <p>Thème : {{ app.user.theme.name }}</p>
            {% endif %}

        </div>

        <nav class="sidebar-menu">

            <ul>

                <li>
                    <a href="{{ path('app_dashboard') }}">
                        Tableau de bord
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_daily_entry_new') }}">
                        Saisie quotidienne
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_daily_entry_index') }}">
                        Historique
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_theme_index') }}">
                        Choix du thème
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_logout') }}">
                        Déconnexion
                    </a>
                </li>

            </ul>

        </nav>

    </aside>

    <section class="dashboard-content">

        <header class="dashboard-header">

            <h1>Tableau de bord</h1>

        </header>

        {% if latest_daily_entry %}

            <section class="dashboard-grid">

                <article class="card score">

                    <h2>Score global</h2>

                    <p class="score-value">
                        {{ latest_daily_entry.score }}
                        <span>/ 50</span>
                    </p>

                    <p class="score-state">
                        État :

                        {% if latest_daily_entry.state == 'good' %}
                            <strong>Bon</strong>
                        {% elseif latest_daily_entry.state == 'medium' %}
                            <strong>Moyen</strong>
                        {% elseif latest_daily_entry.state == 'weak' %}
                            <strong>Faible</strong>
                        {% else %}
                            <strong>{{ latest_daily_entry.state }}</strong>
                        {% endif %}

                    </p>

                </article>

                <article class="card indicators">

                    <h2>Indicateurs</h2>

                    <p>
                        Sommeil :
                        <strong>{{ latest_daily_entry.sleepHours }} h</strong>
                    </p>

                    <p>
                        Énergie :
                        <strong>{{ latest_daily_entry.energy }} / 10</strong>
                    </p>

                    <p>
                        Stress :
                        <strong>{{ latest_daily_entry.stress }} / 10</strong>
                    </p>

                    <p>
                        Motivation :
                        <strong>{{ latest_daily_entry.motivation }} / 10</strong>
                    </p>

                    <p>
                        Humeur :
                        <strong>{{ latest_daily_entry.mood }} / 10</strong>
                    </p>

                </article>

                <article class="card evolution">

                    <h2>Évolution</h2>

                    <p>
                        Consultez votre historique pour suivre
                        l'évolution de vos saisies quotidiennes.
                    </p>

                    <a
                        href="{{ path('app_daily_entry_index') }}"
                        class="dashboard-card-button"
                    >
                        Voir mon historique
                    </a>

                </article>

                <article class="card messages">

                    <h2>Messages / Conseils</h2>

                    <div class="dashboard-message">

                        <p>
                            {{ latest_daily_entry.message }}
                        </p>

                    </div>

                    <div class="dashboard-advice">

                        <p>
                            {{ latest_daily_entry.advice }}
                        </p>

                    </div>

                </article>

            </section>

        {% else %}

            <section class="dashboard-empty">

                <div class="dashboard-empty-content">

                    <h2>
                        Bienvenue {{ app.user.firstname }}
                    </h2>

                    <p class="dashboard-empty-intro">
                        Votre aventure Logic Coach commence maintenant.
                    </p>

                    <p>
                        Pour découvrir votre premier bilan,
                        renseignez vos indicateurs du jour.
                    </p>

                    <div class="dashboard-empty-indicators">

                        <span>Sommeil</span>

                        <span>Énergie</span>

                        <span>Stress</span>

                        <span>Motivation</span>

                        <span>Humeur</span>

                    </div>

                    <p>
                        Logic Coach analysera votre saisie pour vous aider
                        à mieux suivre votre bien-être au quotidien.
                    </p>

                    <a
                        href="{{ path('app_daily_entry_new') }}"
                        class="dashboard-empty-button"
                    >
                        Faire ma première saisie
                    </a>

                </div>

            </section>

        {% endif %}

    </section>

</main>

{% endblock %}